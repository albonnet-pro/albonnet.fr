# ─── Base de données ──────────────────────────────────────────
# PostgreSQL via Docker
DATABASE_URL="a_completer"
DB_PASSWORD="changeme_db_password"

# ─── NextAuth ─────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin (premier compte) ──────────────────────────────────
ADMIN_EMAIL="a_completer"
ADMIN_PASSWORD="changeme_admin_password"

# ─── Email (Resend) ───────────────────────────────────────────
# Créer un compte sur https://resend.com → API Keys → Create API Key
RESEND_API_KEY="a_completer"
# Adresse qui reçoit les messages du formulaire de contact
CONTACT_EMAIL="a_completer"
# Domaine vérifié sur Resend (pour l'adresse expéditrice noreply@...)
RESEND_DOMAIN="a_completer"

NTFY_URL=a_completer
NTFY_TOPIC=a_completer
NTFY_TOKEN=a_completer